# 需求链平台环境变量
# 复制此文件为 .env 并填写实际值

# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=sk-your-key-here

# 数据库（Docker内自动连接，本地开发用此地址）
DATABASE_URL=postgresql+asyncpg://dc:dc_dev_2026@localhost:5432/demand_chain

# 日志级别：DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Worker 轮询间隔（秒）
WORKER_INTERVAL_SECONDS=60

# 告警 Webhook URL（Worker 连续匹配失败时通知）
# 支持 Server酱 (https://sct.ftqq.com/sendkey) 或 企业微信机器人 Webhook URL
# 留空则不发送告警
# ALERT_WEBHOOK_URL=https://sctapi.ftqq.com/YOUR-SENDKEY.send
# ALERT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR-KEY
