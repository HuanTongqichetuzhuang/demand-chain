# 需求链平台 · 环境变量模板
# 复制为 .env 文件并填入你的密钥

# DeepSeek API Key（必填 — 分类/结构化/学术总结）
DEEPSEK_API_KEY=sk-your-key-here

# Firecrawl API Key（可选 — 网页爬虫）
FIRECRAWL_API_KEY=fc-your-key-here

# PostgreSQL 连接（可选 — 默认值适用于本地开发）
# DATABASE_URL=postgresql+asyncpg://dc:dc_dev_2026@localhost:5432/demand_chain

# Redis（可选）
# REDIS_URL=redis://localhost:6379/0

# SMTP 邮件（可选 — 通知/验证邮件）
# SMTP_HOST=smtp.qiye.163.com
# SMTP_PORT=465
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-password

# 告警 Webhook（可选）
# ALERT_WEBHOOK_URL=https://hooks.example.com/alert

# 日志级别（可选 — 默认 INFO）
# LOG_LEVEL=DEBUG
